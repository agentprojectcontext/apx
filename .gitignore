node_modules/

# Web build artifacts (vite output)
src/interfaces/web/dist/

# Playwright run output
src/interfaces/web/test-results/
src/interfaces/web/e2e/reports/
src/interfaces/web/playwright-report/

# APC context skill — canonical source is agentprojectcontext/apc (synced at install/prepack)
skills/apc-context/

# Runtime data — never commit real session logs or runtime state
**/.apc/messages/*.jsonl
**/.apc/messages/*.md
**/.apc/agents/*/sessions/*.md
**/.apc/agents/*/conversations/*.md

# Global APX home (user config, tokens, state)
.apx/

# Env / secrets
.env
.env.*
!.env.example

# macOS
.DS_Store
testing
opencode_ref/

# Claude Code worktrees / local state
.claude/

/tmp

# QA artifacts — local only (raw logs may contain config dumps with secrets)
qa/
# Build artifacts (root) — compiled CLI/TUI, not shipped to npm
/dist/

# Internal planning docs — local only (ADRs, roadmap, PRDs, backlog)
/spec/
