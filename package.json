{
  "name": "@agentprojectcontext/apx",
  "version": "1.22.1",
  "description": "APX — unified CLI + daemon for the Agent Project Context (APC) standard.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "apx": "./src/cli/index.js",
    "apx-daemon": "./src/daemon/index.js",
    "apx-mcp": "./src/mcp/index.js"
  },
  "files": [
    "src/",
    "skills/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/daemon/index.js",
    "smoke": "node src/daemon/smoke.js",
    "test": "node --test --test-reporter=spec tests/*.test.js",
    "upgrade": "pnpm install && pnpm add -g .",
    "prepack": "node scripts/sync-apc-skill.js",
    "postinstall": "node src/cli/postinstall.js"
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-cursor": "^5.0.0",
    "cron-parser": "^5.5.0",
    "express": "^4.21.0",
    "node-fetch": "^3.3.2"
  },
  "optionalDependencies": {
    "fast-glob": "^3.3.2",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.7.0",
    "better-sqlite3": "^11.3.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "apc",
    "apx",
    "agents",
    "mcp",
    "daemon",
    "claude",
    "ai"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "puppeteer"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentprojectcontext/apx.git"
  },
  "homepage": "https://github.com/agentprojectcontext/apx"
}
