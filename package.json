{
  "name": "@agentprojectcontext/apx",
  "version": "1.17.0",
  "description": "APX — unified CLI + daemon for the Agent Project Context (APC) standard.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "apx": "./src/cli/index.js",
    "apx-daemon": "./src/daemon/index.js",
    "apx-mcp": "./src/mcp/index.js",
    "apx-ng": "./dist/cli/index.js"
  },
  "files": [
    "src/",
    "skills/",
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/daemon/index.js",
    "smoke": "node src/daemon/smoke.js",
    "test": "node --test --test-reporter=spec tests/*.test.js",
    "build": "node scripts/build-cli.js",
    "build:watch": "node scripts/build-cli.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.cli.json",
    "upgrade": "pnpm install && pnpm add -g .",
    "prepack": "node scripts/sync-apc-skill.js",
    "postinstall": "node src/cli/postinstall.js"
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.2.8",
    "@opentui/keymap": "^0.2.8",
    "@opentui/solid": "^0.2.8",
    "@solid-primitives/event-bus": "^1.1.3",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "ansi-regex": "^6.2.2",
    "chalk": "^5.6.2",
    "cli-cursor": "^5.0.0",
    "cli-sound": "^1.1.3",
    "clipboardy": "^5.3.1",
    "cron-parser": "^5.5.0",
    "effect": "^3.21.2",
    "express": "^4.21.0",
    "fuzzysort": "^3.1.0",
    "jsonc-parser": "^3.3.1",
    "node-fetch": "^3.3.2",
    "open": "^11.0.0",
    "opentui-spinner": "^0.0.6",
    "react": "^19.2.6",
    "remeda": "^2.34.1",
    "semver": "^7.8.0",
    "solid-js": "^1.9.12",
    "strip-ansi": "^7.2.0",
    "yargs": "^18.0.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "fast-glob": "^3.3.2",
    "puppeteer": "^22.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.7.0",
    "@types/yargs": "^17.0.35",
    "babel-preset-solid": "^1.9.12",
    "better-sqlite3": "^11.3.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "electron": "^33.4.11",
    "esbuild": "^0.28.0",
    "esbuild-plugin-solid": "^0.6.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "apc",
    "apx",
    "agents",
    "mcp",
    "daemon",
    "claude",
    "ai"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "puppeteer"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentprojectcontext/apx.git"
  },
  "homepage": "https://github.com/agentprojectcontext/apx"
}
